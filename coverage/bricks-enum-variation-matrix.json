          "kind": "pass",
          "path": "samples/bricks/implementation-samples/source-target-cases"
        }
      ],
      "rows": [
        {
          "id": "source-code-elements",
          "name": "Source code elements observed at normal code boundaries",
          "outcome": "pass",
          "evidence": "source-target-cases",
          "values": {
            "BrickElementKind": [ "Assembly", "Namespace", "Type", "Member", "Attribute" ],
            "BrickScope": [ "Assembly", "Namespace", "Type", "Member" ],
            "BrickElementOrigin": [ "Source" ],
            "BrickElementSource": [ "Code", "Convention" ]
          }
        },
        {
          "id": "configured-and-external-elements",
          "name": "Configured dependency registrations and external references",
          "outcome": "pass",
          "evidence": "source-target-cases",
          "values": {
            "BrickElementKind": [ "DependencyRegistration", "ExternalReference" ],
            "BrickScope": [ "Global" ],
            "BrickElementOrigin": [ "Generated", "External", "Metadata" ],
            "BrickElementSource": [ "Configuration", "Inference", "Import" ]
          }
        },
        {
          "id": "unknown-element-boundary",
          "name": "Unknown element metadata is explicit instead of silently inferred",
          "outcome": "documentation",
          "evidence": "sample-brick-model",
          "values": {
            "BrickElementKind": [ "Unknown" ],
            "BrickElementOrigin": [ "Unknown" ],
            "BrickElementSource": [ "Unknown" ]
          }
        }
      ]
