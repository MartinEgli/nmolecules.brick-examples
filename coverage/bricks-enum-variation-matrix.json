  "families": [
    {
      "id": "element-classification",
      "name": "Element classification and source modeling",
      "support": "runtime-backed",
      "enums": [
        "BrickElementKind",
        "BrickScope",
        "BrickElementOrigin",
        "BrickElementSource"
      ],
      "samples": [
        {
          "id": "sample-brick-model",
